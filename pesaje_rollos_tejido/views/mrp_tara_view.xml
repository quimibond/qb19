<odoo>
    <record id="view_mrp_tara_tree" model="ir.ui.view">
        <field name="name">mrp.tara.list</field>
        <field name="model">mrp.tara</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="workcenter_id"/>
                <field name="tara"/>
            </list>
        </field>
    </record>

    <record id="action_mrp_tara_config" model="ir.actions.act_window">
        <field name="name">Configuración de Taras</field>
        <field name="res_model">mrp.tara</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_mrp_tara" 
              name="Taras de Pesaje" 
              parent="mrp.menu_mrp_configuration" 
              action="action_mrp_tara_config" 
              sequence="100"/>
</odoo>