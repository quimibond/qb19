<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_weigh_roll_wizard_form" model="ir.ui.view">
        <field name="name">mrp.weigh.roll.wizard.form</field>
        <field name="model">mrp.weigh.roll.wizard</field>
        <field name="arch" type="xml">
            <form string="Registro de Pesaje">
                <sheet>
                    <div class="row">
                        <div class="col-6">
                            <strong>Orden de Trabajo: </strong> <field name="workorder_id" readonly="1"/><br/>
                            <strong>Centro de Trabajo: </strong> <field name="workcenter_id" readonly="1"/>
                        </div>
                        <div class="col-6 text-end">
                            <strong>Artículo: </strong> <field name="product_id" readonly="1"/>
                        </div>
                    </div>
                    <hr/>
                    <div class="row">
                        <div class="col-6 border-end">
                            <group string="PROGRESO DE PRODUCCIÓN">
                                <field name="qty_to_produce" readonly="1"/>
                                <field name="qty_produced" readonly="1" decoration-success="1" style="font-weight: bold;"/>
                                <field name="production_percentage" widget="percentage"/>
                            </group>
                        </div>
                        <div class="col-6">
                            <group string="IDENTIFICACIÓN DEL ROLLO">
                                <field name="roll_count" readonly="1" string="Rollos Previos" style="font-weight: bold; color: #008784;"/>
                                <field name="next_lot_name" readonly="1" style="font-weight: bold; color: #714B67; font-size: 1.1em;"/>
                            </group>
                        </div>
                    </div>

                    <div class="text-center mt-4 mb-4 p-4 border rounded bg-light">
                        <div class="row">
                            <div class="col-4">
                                <label for="weight" string="PESO BRUTO" style="font-size: 1.2em; font-weight: bold; color: #666;"/><br/>
                                <field name="weight" style="font-size: 3em; font-weight: bold; width: 90%; text-align: center;" class="oe_inline"/>
                            </div>
                            <div class="col-4">
                                <label for="tara" string="TARA" style="font-size: 1.2em; font-weight: bold; color: #a24646;"/><br/>
                                <field name="tara" readonly="1" style="font-size: 3em; font-weight: bold; width: 90%; text-align: center; color: #a24646;" class="oe_inline"/>
                            </div>
                            <div class="col-4">
                                <label for="net_weight" string="PESO NETO" style="font-size: 1.2em; font-weight: bold; color: #008784;"/><br/>
                                <field name="net_weight" readonly="1" style="font-size: 4em; font-weight: bold; width: 90%; text-align: center; color: #008784;" class="oe_inline"/>
                            </div>
                        </div>
                        <div class="mt-2">
                            <span style="font-size: 2em; font-weight: bold;">KG</span>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button name="confirm_weighing" string="REGISTRAR E IMPRIMIR ETIQUETA" type="object" class="btn-primary btn-lg"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>