<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_mrp_pesaje" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.mrp.pesaje</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='mrp']" position="inside">
                <block title="Pesaje y Calidad de Rollos" name="pesaje_rollos_settings">
                    <setting string="Muestreo de Calidad" help="Porcentaje de rollos para revisión.">
                        <field name="qc_sample_percentage"/>
                        <span>%</span>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>