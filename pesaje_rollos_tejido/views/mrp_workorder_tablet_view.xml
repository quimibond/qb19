<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_custom_weighing" model="ir.actions.act_window">
        <field name="name">Registro de Pesaje</field>
        <field name="res_model">mrp.weigh.roll.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_workorder_id': active_id}</field>
    </record>

    <record id="action_mrp_subproduct_wizard" model="ir.actions.act_window">
        <field name="name">Pesaje Subproducto</field>
        <field name="res_model">mrp.subproduct.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_workorder_id': active_id}</field>
    </record>

    <record id="mrp_workorder_view_tree_inherit_weigh" model="ir.ui.view">
        <field name="name">mrp.workorder.view.list.inherit.weigh</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_editable_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="product_id_category_name" column_invisible="1"/>
                
                <button name="%(pesaje_rollos_tejido.action_custom_weighing)d" 
                        type="action" string="PESAR" class="btn-primary" icon="fa-balance-scale"
                        invisible="product_id_category_name != 'Producto En Proceso / Tac-Producto en proceso-Tejido Circular-kg'"/>
                <button name="%(pesaje_rollos_tejido.action_mrp_subproduct_wizard)d" 
                        type="action" string="SUBPRODUCTO" class="btn-secondary" icon="fa-recycle"
                        invisible="product_id_category_name != 'Producto En Proceso / Tac-Producto en proceso-Tejido Circular-kg'"/>
            </xpath>
        </field>
    </record>
</odoo>