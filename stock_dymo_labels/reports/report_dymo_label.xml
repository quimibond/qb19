<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="line">
                    <div class="page">
                        <style>
                            /* Forzamos que cada etiqueta ocupe el tamaño exacto del papel */
                            .label-container {
                                width: 100%;
                                height: 72mm; /* Un poco menos de 76mm para evitar desbordes */
                                font-family: 'Helvetica', Arial, sans-serif;
                                color: black;
                                text-align: center;
                                padding-top: 2mm;
                                overflow: hidden;
                                position: relative;
                                page-break-after: always; /* Crucial para separar etiquetas */
                            }
                            
                            .label-ref {
                                font-size: 32px;
                                font-weight: bold;
                                margin-bottom: 5px;
                                display: block;
                                text-transform: uppercase;
                            }
                            
                            .label-name {
                                font-size: 28px;
                                line-height: 1.1;
                                margin-bottom: 8px;
                                display: block;
                                padding: 0 4mm;
                                max-height: 65px;
                                overflow: hidden;
                            }
                            
                            .label-data {
                                font-size: 26px;
                                margin-bottom: 5px;
                                display: block;
                            }
                            
                            .barcode-box {
                                margin-top: 5px;
                                width: 100%;
                            }
                            
                            .lot-text {
                                font-size: 22px;
                                font-weight: bold;
                                margin-top: 2px;
                            }
                        </style>

                        <div class="label-container">
                            <span class="label-ref">
                                REF: <t t-esc="line.product_id.default_code or 'N/A'"/>
                            </span>
                            
                            <span class="label-name">
                                <t t-esc="line.product_id.name"/>
                            </span>
                            
                            <span class="label-data">
                                <strong>Lote:</strong> <t t-esc="line.lot_id.name"/>
                                <span style="margin-left: 15px;">
                                    <strong>Cant:</strong> <t t-esc="int(line.quantity)"/>
                                </span>
                            </span>
                            
                            <span class="label-data">
                                <strong>Num. CAJA:</strong> 
                                <t t-esc="line.lot_id.name[-4:] if line.lot_id and line.lot_id.name else '0000'"/>
                            </span>

                            <div class="barcode-box">
                                <t t-if="line.lot_id.name">
                                    <img t-att-src="'/report/barcode/?symbology=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', line.lot_id.name, 600, 100)" 
                                         style="width:85%; height:20mm;"/>
                                    <div class="lot-text">
                                        <t t-esc="line.lot_id.name"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>