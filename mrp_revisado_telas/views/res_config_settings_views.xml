<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_mrp_revisado" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.mrp.revisado</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='mrp']" position="inside">
                <block title="Control de Calidad Textil" name="quality_textile_sorteo">
                    <setting title="Sorteo de Revisión" help="Porcentaje de rollos para revisión de peso">
                        <div class="content-group">
                            <div class="mt16">
                                <label for="mrp_revision_percentage" string="% Rollos a Revisar"/>
                                <field name="mrp_revision_percentage" widget="percentage" class="oe_inline"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>