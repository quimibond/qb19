<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- == Query Form (modal) == -->
    <record id="view_query_form" model="ir.ui.view">
        <field name="name">intelligence.query.form</field>
        <field name="model">intelligence.query</field>
        <field name="arch" type="xml">
            <form string="Consulta de Inteligencia">
                <sheet>
                    <div class="oe_title mb-3">
                        <h2>Pregunta al cerebro de Quimibond</h2>
                        <p class="text-muted">
                            El sistema busca en emails, Odoo, briefings y alertas
                            para darte una respuesta con contexto real.
                        </p>
                    </div>
                    <group>
                        <field name="question" nolabel="1"
                               placeholder="Ej: Que esta pasando con el cliente X? Quien no ha respondido esta semana? Cuanto nos deben los clientes principales?"/>
                    </group>
                    <div class="text-center mb-3">
                        <button name="action_ask" type="object"
                                string="Preguntar" class="btn-primary btn-lg"
                                icon="fa-brain"/>
                    </div>
                    <div invisible="not answer" class="mt-4">
                        <h3>Respuesta</h3>
                        <field name="answer" readonly="1" nolabel="1"/>
                    </div>
                    <div invisible="not context_used" class="mt-3">
                        <details>
                            <summary class="text-muted">
                                Contexto utilizado (datos del ERP y emails)
                            </summary>
                            <field name="context_used" readonly="1" nolabel="1"/>
                        </details>
                    </div>
                </sheet>
                <footer>
                    <button name="action_ask" type="object"
                            string="Preguntar" class="btn-primary"
                            invisible="answer"/>
                    <button string="Cerrar" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_query" model="ir.actions.act_window">
        <field name="name">Preguntar al cerebro</field>
        <field name="res_model">intelligence.query</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
