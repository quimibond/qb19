<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- == Briefing List == -->
    <record id="view_briefing_tree" model="ir.ui.view">
        <field name="name">intelligence.briefing.tree</field>
        <field name="model">intelligence.briefing</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-muted="state == 'archived'">
                <field name="date"/>
                <field name="briefing_type" widget="badge"
                       decoration-info="briefing_type == 'daily'"
                       decoration-success="briefing_type == 'weekly'"/>
                <field name="total_emails"/>
                <field name="accounts_ok" string="Cuentas OK"/>
                <field name="accounts_failed" string="Fallidas"
                       decoration-danger="accounts_failed > 0"/>
                <field name="topics_count" string="Temas"/>
                <field name="alert_count" string="Alertas"
                       decoration-danger="alert_count > 5"
                       decoration-warning="alert_count > 0"/>
                <field name="execution_seconds" string="Duracion (s)"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'reviewed'"
                       decoration-info="state == 'draft'"
                       decoration-muted="state == 'archived'"/>
            </list>
        </field>
    </record>

    <!-- == Briefing Form == -->
    <record id="view_briefing_form" model="ir.ui.view">
        <field name="name">intelligence.briefing.form</field>
        <field name="model">intelligence.briefing</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_reviewed" type="object"
                            string="Marcar como revisado"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,reviewed,archived"/>
                </header>
                <sheet>
                    <div class="oe_title mb-3">
                        <h1>
                            <span invisible="briefing_type != 'daily'">Briefing Diario</span>
                            <span invisible="briefing_type != 'weekly'">Reporte Semanal</span>
                            - <field name="date" readonly="1" class="oe_inline"/>
                        </h1>
                    </div>
                    <div class="row mb-4">
                        <div class="col-lg-3 col-6">
                            <div class="o_stat_info text-center p-2 border rounded">
                                <span class="o_stat_text text-muted">Emails</span>
                                <span class="o_stat_value">
                                    <field name="total_emails" class="oe_inline"/>
                                </span>
                            </div>
                        </div>
                        <div class="col-lg-3 col-6">
                            <div class="o_stat_info text-center p-2 border rounded">
                                <span class="o_stat_text text-muted">Cuentas OK / Fallidas</span>
                                <span class="o_stat_value">
                                    <field name="accounts_ok" class="oe_inline"/> /
                                    <field name="accounts_failed" class="oe_inline"/>
                                </span>
                            </div>
                        </div>
                        <div class="col-lg-3 col-6">
                            <div class="o_stat_info text-center p-2 border rounded">
                                <span class="o_stat_text text-muted">Temas</span>
                                <span class="o_stat_value">
                                    <field name="topics_count" class="oe_inline"/>
                                </span>
                            </div>
                        </div>
                        <div class="col-lg-3 col-6">
                            <div class="o_stat_info text-center p-2 border rounded">
                                <span class="o_stat_text text-muted">Alertas</span>
                                <span class="o_stat_value">
                                    <field name="alert_count" class="oe_inline"/>
                                </span>
                            </div>
                        </div>
                    </div>
                    <notebook>
                        <page string="Briefing" name="briefing">
                            <field name="html_content" readonly="1"/>
                        </page>
                        <page string="Alertas" name="alerts">
                            <field name="alert_ids">
                                <list>
                                    <field name="severity" widget="badge"
                                           decoration-danger="severity in ('critical','high')"
                                           decoration-warning="severity == 'medium'"
                                           decoration-info="severity == 'low'"/>
                                    <field name="alert_type"/>
                                    <field name="name"/>
                                    <field name="account"/>
                                    <field name="partner_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'resolved'"
                                           decoration-danger="state == 'open'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Temas detectados" name="topics">
                            <field name="topics_json" readonly="1"/>
                        </page>
                        <page string="Datos tecnicos" name="tech">
                            <group col="4">
                                <field name="briefing_type"/>
                                <field name="execution_seconds"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- == Briefing Search == -->
    <record id="view_briefing_search" model="ir.ui.view">
        <field name="name">intelligence.briefing.search</field>
        <field name="model">intelligence.briefing</field>
        <field name="arch" type="xml">
            <search>
                <field name="date"/>
                <filter name="daily" string="Diarios"
                        domain="[('briefing_type','=','daily')]"/>
                <filter name="weekly" string="Semanales"
                        domain="[('briefing_type','=','weekly')]"/>
                <separator/>
                <filter name="draft" string="Sin revisar"
                        domain="[('state','=','draft')]"/>
                <filter name="with_alerts" string="Con alertas"
                        domain="[('alert_count','>',0)]"/>
                <separator/>
                <filter name="this_week" string="Esta semana"
                        domain="[('date','>=', (context_today() - datetime.timedelta(days=7)).strftime('%%Y-%%m-%%d'))]"/>
                <filter name="this_month" string="Este mes"
                        domain="[('date','>=', context_today().strftime('%%Y-%%m-01'))]"/>
                <group>
                    <filter name="group_type" string="Tipo"
                            context="{'group_by': 'briefing_type'}"/>
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_briefings" model="ir.actions.act_window">
        <field name="name">Briefings</field>
        <field name="res_model">intelligence.briefing</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>

</odoo>
