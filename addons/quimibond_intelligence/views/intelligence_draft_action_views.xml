<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- == Draft Action List == -->
    <record id="view_draft_action_tree" model="ir.ui.view">
        <field name="name">intelligence.draft.action.tree</field>
        <field name="model">intelligence.draft.action</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-success="state == 'executed'"
                  decoration-muted="state == 'rejected'">
                <field name="create_date" string="Fecha" widget="date"/>
                <field name="draft_type" widget="badge"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state in ('approved','executed')"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- == Draft Action Form == -->
    <record id="view_draft_action_form" model="ir.ui.view">
        <field name="name">intelligence.draft.action.form</field>
        <field name="model">intelligence.draft.action</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object"
                            string="Aprobar y Ejecutar" class="btn-success"
                            invisible="state != 'draft'"/>
                    <button name="action_reject" type="object"
                            string="Rechazar"
                            invisible="state != 'draft'"/>
                    <button name="action_reset" type="object"
                            string="Volver a borrador"
                            invisible="state not in ('rejected','approved')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,executed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group col="4">
                        <field name="draft_type"/>
                        <field name="partner_id"/>
                        <field name="action_item_id"/>
                        <field name="alert_id"/>
                    </group>
                    <group string="Datos del borrador" invisible="not draft_data">
                        <field name="draft_data" widget="ace" options="{'mode': 'json'}"/>
                    </group>
                    <group string="Resultado" invisible="state != 'executed'">
                        <field name="executed_ref"/>
                    </group>
                    <field name="notes" placeholder="Notas adicionales..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- == Search == -->
    <record id="view_draft_action_search" model="ir.ui.view">
        <field name="name">intelligence.draft.action.search</field>
        <field name="model">intelligence.draft.action</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <separator/>
                <filter name="state_draft" string="Pendientes"
                        domain="[('state','=','draft')]"/>
                <filter name="state_executed" string="Ejecutados"
                        domain="[('state','=','executed')]"/>
                <group>
                    <filter name="group_type" string="Tipo"
                            context="{'group_by': 'draft_type'}"/>
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_draft_actions" model="ir.actions.act_window">
        <field name="name">Acciones Sugeridas</field>
        <field name="res_model">intelligence.draft.action</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_state_draft': 1}</field>
    </record>

</odoo>
