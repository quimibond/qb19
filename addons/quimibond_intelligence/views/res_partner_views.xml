<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_intelligence" model="ir.ui.view">
        <field name="name">res.partner.form.intelligence</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Inteligencia" name="intelligence">
                    <group col="4">
                        <field name="intelligence_score" string="Score"/>
                        <field name="intelligence_risk" string="Riesgo"/>
                        <field name="intelligence_alert_count"
                               string="Alertas abiertas"/>
                    </group>
                    <separator string="Historial de scores"/>
                    <field name="intelligence_score_ids">
                        <list>
                            <field name="date"/>
                            <field name="total_score"/>
                            <field name="frequency_score"/>
                            <field name="responsiveness_score"/>
                            <field name="reciprocity_score"/>
                            <field name="sentiment_score"/>
                            <field name="risk_level" widget="badge"
                                   decoration-danger="risk_level == 'high'"
                                   decoration-warning="risk_level == 'medium'"
                                   decoration-success="risk_level == 'low'"/>
                            <field name="score_trend"/>
                        </list>
                    </field>
                    <separator string="Alertas"/>
                    <field name="intelligence_alert_ids">
                        <list>
                            <field name="create_date" string="Fecha"/>
                            <field name="severity" widget="badge"/>
                            <field name="alert_type"/>
                            <field name="name"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
