<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_intelligence" model="ir.ui.view">
        <field name="name">res.partner.form.intelligence</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Inteligencia" name="intelligence">

                    <!-- ═══ KPI Stats Row ═══ -->
                    <group col="8">
                        <div class="o_stat_info text-center">
                            <span class="o_stat_value">
                                <field name="intelligence_score" class="oe_inline"/>
                                <span class="text-muted">/100</span>
                            </span>
                            <span class="o_stat_text">Score</span>
                        </div>
                        <div class="o_stat_info text-center">
                            <span class="o_stat_value">
                                <field name="intelligence_risk" class="oe_inline"
                                       widget="badge"
                                       decoration-danger="intelligence_risk == 'high'"
                                       decoration-warning="intelligence_risk == 'medium'"
                                       decoration-success="intelligence_risk == 'low'"/>
                            </span>
                            <span class="o_stat_text">Riesgo</span>
                        </div>
                        <div class="o_stat_info text-center">
                            <span class="o_stat_value">
                                <field name="intelligence_alert_count" class="oe_inline"/>
                            </span>
                            <span class="o_stat_text">Alertas</span>
                        </div>
                        <div class="o_stat_info text-center">
                            <span class="o_stat_value text-danger">
                                <field name="intel_total_overdue" class="oe_inline" widget="monetary"/>
                            </span>
                            <span class="o_stat_text">Vencido</span>
                        </div>
                        <div class="o_stat_info text-center">
                            <span class="o_stat_value">
                                <field name="intel_overdue_count" class="oe_inline"/>
                            </span>
                            <span class="o_stat_text">Fact. Vencidas</span>
                        </div>
                        <div class="o_stat_info text-center">
                            <span class="o_stat_value">
                                <field name="intel_pending_deliveries" class="oe_inline"/>
                                <span class="text-danger" invisible="intel_late_deliveries == 0">
                                    (<field name="intel_late_deliveries" class="oe_inline"/> tarde)
                                </span>
                            </span>
                            <span class="o_stat_text">Entregas</span>
                        </div>
                        <div class="o_stat_info text-center">
                            <span class="o_stat_value text-primary">
                                <field name="intel_crm_pipeline_value" class="oe_inline" widget="monetary"/>
                            </span>
                            <span class="o_stat_text">Pipeline</span>
                        </div>
                        <div class="o_stat_info text-center">
                            <span class="o_stat_value">
                                <field name="intel_pending_activities" class="ee_inline"/>
                                <span class="text-danger" invisible="intel_overdue_activities == 0">
                                    (<field name="intel_overdue_activities" class="oe_inline"/> vencidas)
                                </span>
                            </span>
                            <span class="o_stat_text">Actividades</span>
                        </div>
                    </group>

                    <!-- ═══ Sub-tabs ═══ -->
                    <notebook>
                        <!-- Panorama 360 -->
                        <page string="Panorama 360" name="panorama">
                            <field name="intelligence_panorama" readonly="1" nolabel="1"/>
                        </page>

                        <!-- Finanzas -->
                        <page string="Finanzas" name="intel_finance">
                            <group col="4">
                                <group string="Resumen Financiero">
                                    <field name="intel_total_invoiced" widget="monetary"/>
                                    <field name="intel_total_overdue" widget="monetary"/>
                                    <field name="intel_overdue_count"/>
                                </group>
                                <group string="CRM Pipeline">
                                    <field name="intel_crm_pipeline_value" widget="monetary"/>
                                    <field name="intel_crm_opportunity_count"/>
                                </group>
                            </group>
                        </page>

                        <!-- Operaciones -->
                        <page string="Operaciones" name="intel_operations">
                            <group col="4">
                                <group string="Entregas">
                                    <field name="intel_pending_deliveries"/>
                                    <field name="intel_late_deliveries"/>
                                </group>
                                <group string="Actividades">
                                    <field name="intel_pending_activities"/>
                                    <field name="intel_overdue_activities"/>
                                </group>
                            </group>
                        </page>

                        <!-- Historial de Scores -->
                        <page string="Scores" name="scores">
                            <field name="intelligence_score_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="total_score" string="Score"
                                           decoration-danger="total_score &lt; 35"
                                           decoration-warning="total_score &lt; 60"
                                           decoration-success="total_score >= 60"/>
                                    <field name="frequency_score" string="Frecuencia" optional="show"/>
                                    <field name="responsiveness_score" string="Respuesta" optional="show"/>
                                    <field name="reciprocity_score" string="Reciprocidad" optional="show"/>
                                    <field name="sentiment_score" string="Sentimiento" optional="show"/>
                                    <field name="payment_compliance_score" string="Compliance Pago" optional="show"/>
                                    <field name="risk_level" widget="badge"
                                           decoration-danger="risk_level == 'high'"
                                           decoration-warning="risk_level == 'medium'"
                                           decoration-success="risk_level == 'low'"/>
                                    <field name="score_trend" widget="badge"
                                           decoration-success="score_trend == 'up'"
                                           decoration-danger="score_trend == 'down'"
                                           decoration-muted="score_trend == 'stable'"
                                           optional="show"/>
                                </list>
                            </field>
                        </page>

                        <!-- Alertas -->
                        <page string="Alertas" name="alerts">
                            <field name="intelligence_alert_ids" readonly="1">
                                <list decoration-danger="state == 'open' and severity in ('high','critical')"
                                      decoration-muted="state in ('resolved','dismissed')">
                                    <field name="create_date" string="Fecha" widget="date"/>
                                    <field name="severity" widget="badge"
                                           decoration-danger="severity in ('critical','high')"
                                           decoration-warning="severity == 'medium'"
                                           decoration-info="severity == 'low'"/>
                                    <field name="alert_type"/>
                                    <field name="name"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'resolved'"
                                           decoration-danger="state == 'open'"/>
                                </list>
                            </field>
                        </page>

                        <!-- Acciones -->
                        <page string="Acciones" name="actions">
                            <field name="intelligence_action_ids" readonly="1">
                                <list decoration-danger="is_overdue"
                                      decoration-muted="state in ('done','cancelled')">
                                    <field name="create_date" string="Creada" widget="date"/>
                                    <field name="priority" widget="badge"
                                           decoration-danger="priority in ('critical','high')"
                                           decoration-warning="priority == 'medium'"/>
                                    <field name="name"/>
                                    <field name="action_type"/>
                                    <field name="assignee_id" widget="many2one_avatar_user"/>
                                    <field name="due_date"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'done'"
                                           decoration-danger="state == 'open'"/>
                                    <field name="is_overdue" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
