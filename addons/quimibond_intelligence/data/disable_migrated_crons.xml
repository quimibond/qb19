<?xml version="1.0" encoding="utf-8"?>
<!--
    Desactiva los crons que fueron migrados al frontend (Next.js API routes).
    El pipeline ahora corre en Vercel via /api/pipeline/trigger cada 30 min.

    Se mantienen activos:
    - cron_odoo_tables_sync: Sync tablas ERP → Supabase (cada 6h)
    - cron_supabase_sync: Sync alertas/acciones → Supabase (cada 5 min)
    - cron_reverse_sync: Sync frontend → Odoo (cada 5 min)
    - cron_data_retention: Limpieza semanal
-->
<odoo>
    <data noupdate="0">

        <!-- Gmail sync → ahora en /api/pipeline/sync-emails -->
        <record id="cron_sync_emails" model="ir.cron">
            <field name="active">False</field>
        </record>

        <!-- Análisis Claude → ahora en /api/pipeline/analyze -->
        <record id="cron_analyze_emails" model="ir.cron">
            <field name="active">False</field>
        </record>

        <!-- Briefing diario → ahora en /api/pipeline/briefing -->
        <record id="cron_daily_intelligence" model="ir.cron">
            <field name="active">False</field>
        </record>

        <!-- Scores → computados en frontend desde Supabase -->
        <record id="cron_update_scores" model="ir.cron">
            <field name="active">False</field>
        </record>

        <!-- Enrichment Odoo→Supabase contactos → contexto ahora desde Supabase -->
        <record id="cron_enrich_only" model="ir.cron">
            <field name="active">False</field>
        </record>

        <!-- Reporte semanal → trigger manual desde frontend -->
        <record id="cron_weekly_analysis" model="ir.cron">
            <field name="active">False</field>
        </record>

        <!-- Predicciones → trigger manual desde frontend -->
        <record id="cron_predictions" model="ir.cron">
            <field name="active">False</field>
        </record>

        <!-- Briefing replies → usa Gmail API, ahora en frontend -->
        <record id="cron_briefing_replies" model="ir.cron">
            <field name="active">False</field>
        </record>

    </data>
</odoo>
