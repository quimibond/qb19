<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ═══ Cron Diario: 19:00 CDMX (01:00 UTC siguiente día) ═══ -->
        <record id="cron_daily_intelligence" model="ir.cron">
            <field name="name">Intelligence System — Briefing Diario</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_daily_intelligence()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="doall">False</field>
            <!-- 19:00 CDMX (CDT, UTC-5) = 00:00 UTC siguiente día -->
            <field name="nextcall" eval="'2026-03-21 00:00:00'"/>
            <field name="priority">5</field>
        </record>

        <!-- ═══ Cron Semanal: Lunes 08:00 CDMX (14:00 UTC) ═══ -->
        <record id="cron_weekly_analysis" model="ir.cron">
            <field name="name">Intelligence System — Reporte Semanal</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_weekly_analysis()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="doall">False</field>
            <!-- Lunes 08:00 CDMX = 14:00 UTC -->
            <field name="nextcall" eval="'2026-03-23 14:00:00'"/>
            <field name="priority">10</field>
        </record>

    </data>
</odoo>
