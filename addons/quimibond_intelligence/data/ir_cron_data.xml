<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Push Odoo data to Supabase every hour (incremental via write_date) -->
        <record id="cron_push_to_supabase" model="ir.cron">
            <field name="name">Quimibond Sync - Push to Supabase (every 1h)</field>
            <field name="model_id" ref="model_quimibond_sync"/>
            <field name="state">code</field>
            <field name="code">model.push_to_supabase()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(hours=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">5</field>
        </record>

        <!-- Nightly full sync at 3am UTC (covers write_date misses on recompute) -->
        <record id="cron_push_to_supabase_full" model="ir.cron">
            <field name="name">Quimibond Sync - Full Push to Supabase (nightly 3am)</field>
            <field name="model_id" ref="model_quimibond_sync"/>
            <field name="state">code</field>
            <field name="code">model.push_to_supabase_full()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=3, minute=0, second=0, microsecond=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">5</field>
        </record>

        <!-- Pull intelligence commands from Supabase every 5 minutes -->
        <record id="cron_pull_from_supabase" model="ir.cron">
            <field name="name">Quimibond Sync - Pull from Supabase (every 5min)</field>
            <field name="model_id" ref="model_quimibond_sync_pull"/>
            <field name="state">code</field>
            <field name="code">model.pull_from_supabase()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(minutes=5)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">3</field>
        </record>

    </data>
</odoo>
