<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_daily_intelligence" model="ir.cron">
            <field name="name">Intelligence System - Briefing Diario</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_daily_intelligence()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 01:00:00')"/>
        </record>

        <record id="cron_weekly_analysis" model="ir.cron">
            <field name="name">Intelligence System - Reporte Semanal</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_weekly_analysis()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=7)).strftime('%Y-%m-%d 13:00:00')"/>
        </record>

        <!-- ══ Micro-pipelines (alta frecuencia) ══ -->

        <record id="cron_sync_emails" model="ir.cron">
            <field name="name">Intelligence - Sync Emails (cada 30 min)</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_sync_emails()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(minutes=30)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">5</field>
        </record>

        <record id="cron_analyze_emails" model="ir.cron">
            <field name="name">Intelligence - Analizar Emails (cada 2h)</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_analyze_emails()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(hours=2)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">10</field>
        </record>

        <record id="cron_update_scores" model="ir.cron">
            <field name="name">Intelligence - Actualizar Scores (cada 4h)</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_update_scores()</field>
            <field name="interval_number">4</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(hours=4)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">15</field>
        </record>

        <record id="cron_enrich_only" model="ir.cron">
            <field name="name">Intelligence - Sync Odoo→Supabase (cada 6h)</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_enrich_only()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(hours=6)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">12</field>
        </record>

        <record id="cron_supabase_sync" model="ir.cron">
            <field name="name">Intelligence - Supabase Sync (cada 5 min)</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_supabase_sync()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(minutes=5)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">3</field>
        </record>

        <record id="cron_odoo_tables_sync" model="ir.cron">
            <field name="name">Intelligence - Sync Odoo Tables (cada 6h)</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_sync_odoo_tables()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(hours=6)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">13</field>
        </record>

        <record id="cron_predictions" model="ir.cron">
            <field name="name">Intelligence - Predicciones (semanal)</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_predictions()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=7)).strftime('%Y-%m-%d 02:00:00')"/>
            <field name="priority">20</field>
        </record>

        <record id="cron_briefing_replies" model="ir.cron">
            <field name="name">Intelligence - Briefing Replies (cada 30 min)</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_check_briefing_replies()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(minutes=30)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">8</field>
        </record>

        <!-- ══ Tareas de mantenimiento ══ -->

        <record id="cron_data_retention" model="ir.cron">
            <field name="name">Intelligence System - Data Retention (Cleanup)</field>
            <field name="model_id" ref="model_intelligence_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_data_retention()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=7)).strftime('%Y-%m-%d 03:00:00')"/>
        </record>

    </data>
</odoo>
