<odoo>
  <record id="dymo_paperformat" model="report.paperformat">
    <field name="name">Dymo 54x25</field>
    <field name="default" eval="False"/>
    <field name="format">custom</field>
    <field name="page_height">25</field> <!-- mm -->
    <field name="page_width">54</field>  <!-- mm -->
    <field name="orientation">Portrait</field>
    <field name="margin_top">2</field>
    <field name="margin_bottom">2</field>
    <field name="margin_left">2</field>
    <field name="margin_right">2</field>
    <field name="dpi">300</field>
  </record> 
 
  <report
    id="action_stock_label_custom_pdf"
    model="stock.move.line"
    string="Etiqueta PDF"
    report_type="qweb-pdf"
    name="stock_label_custom.report_stock_label_custom_pdf"
    file="stock_label_custom.report_stock_label_custom_pdf"
    paperformat="dymo_paperformat"
  />

  <report
    id="action_stock_label_custom_zpl"
    model="stock.move.line"
    string="Etiqueta ZPL"
    report_type="qweb-text"
    name="stock_label_custom.report_stock_label_custom_zpl"
    file="stock_label_custom.report_stock_label_custom_zpl"
  />
</odoo>
