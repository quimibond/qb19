<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="line">
                <t t-call="web.basic_layout">
                    <style>
                        .label-container {
                            width: 100%;
                            height: 70mm; /* Ajustado al papel */
                            font-family: 'Helvetica', Arial, sans-serif;
                            color: black;
                            padding: 5mm;
                        }
                        .label-ref {
                            font-size: 22px;
                            font-weight: bold;
                            margin-bottom: 5px;
                        }
                        .label-name {
                            font-size: 18px;
                            line-height: 1.2;
                            margin-bottom: 8px;
                            display: block;
                        }
                        .label-data {
                            font-size: 16px;
                            margin-bottom: 10px;
                        }
                        .barcode-box {
                            text-align: center;
                            margin-top: 15px;
                            width: 100%;
                        }
                    </style>

                    <div class="label-container">
                        <div class="label-ref">
                            Ref: <t t-esc="line.product_id.default_code or 'N/A'"/>
                        </div>
                        
                        <div class="label-name">
                            <t t-esc="line.product_id.name"/>
                        </div>
                        
                        <div class="label-data">
                            <strong>Lote:</strong> <t t-esc="line.lot_id.name"/>
                        </div>
                        
                        <div class="label-data">
                            <strong>Cant:</strong> <t t-esc="line.quantity"/> 
                            <span style="margin-left: 20px;">
                                <strong>Caja:</strong> <t t-esc="line.lot_id.name[-4:] if line.lot_id.name else '0000'"/>
                            </span>
                        </div>

                        <div class="barcode-box">
                            <t t-if="line.lot_id.name">
                                <span t-field="line.lot_id.name" 
                                      t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 600, 'height': 120, 'img_style': 'width:90%;height:25mm;'}"/>
                                <div style="font-size: 12px; margin-top: 5px;"><t t-esc="line.lot_id.name"/></div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>