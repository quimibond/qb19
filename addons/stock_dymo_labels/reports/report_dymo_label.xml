<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="line">
                <t t-call="web.basic_layout">
                    <div class="page" style="text-align: center; font-family: sans-serif; color: black; padding-top: 5mm;">
                        <div style="font-size: 42px; font-weight: bold; line-height: 1.1;">
                             <t t-esc="line.product_id.default_code or 'SIN REF'"/>
                        </div>
                        
                        <div style="font-size: 42px; font-weight: bold; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            <t t-esc="line.product_id.name"/>
                        </div>
                        
                        <div style="font-size: 42px; font-weight: bold; line-height: 1.1;">
                            Lote: <t t-esc="line.lot_id.name or 'N/A'"/>
                        </div>
                        
                        <div style="font-size: 42px; font-weight: bold; line-height: 1.1;">
                            Caja: <t t-esc="line.lot_id.name[-4:] if line.lot_id and line.lot_id.name else '0000'"/> 
                            <span style="margin-left: 20px;">Cant: <t t-esc="int(line.quantity)"/></span>
                        </div>

                        <div style="margin-top: 15px; width: 100%;">
                            <t t-if="line.lot_id">
                                <img t-att-src="'/report/barcode/?symbology=Code128&amp;value=' + quote_plus(line.lot_id.name) + '&amp;width=800&amp;height=200&amp;humanreadable=0'" 
                                     style="width: 80%; height: 20mm; display: block; margin: 0 auto;"/>
                                <div style="font-size: 20px; font-weight: bold; margin-top: 5px;">
                                    <t t-esc="line.lot_id.name"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>