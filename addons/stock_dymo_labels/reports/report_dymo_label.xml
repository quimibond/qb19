<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="line">
                <t t-call="web.basic_layout">
                    <style>
                        .label-container {
                            width: 100%;
                            height: 72mm;
                            text-align: center;
                            font-family: 'Helvetica', Arial, sans-serif;
                            padding-top: 4mm;
                        }
                        .label-ref { font-size: 42px; font-weight: bold; display: block; margin-bottom: 5px; }
                        .label-name { font-size: 42px; display: block; margin-bottom: 10px; height: 40px; overflow: hidden; }
                        .label-data { font-size: 42px; font-weight: bold; display: block; margin-bottom: 5px; }
                        
                        /* CONTENEDOR DE ALTA LECTURA */
                        .barcode-zone {
                            margin: 15px auto 0 auto;
                            width: 90%; /* Deja 'zonas de silencio' blancas a los lados */
                        }
                        
                        .barcode-zone img {
                            /* Ajustamos el renderizado para que no suavice los bordes */
                            image-rendering: pixelated; 
                            image-rendering: crisp-edges;
                            width: 100% !important;
                            height: 32mm !important;
                            display: block;
                            margin: 0 auto;
                        }
                    </style>

                    <div class="label-container">
                        <span class="label-ref">REF: <t t-esc="line.product_id.default_code or 'N/A'"/></span>
                        <span class="label-name"><t t-esc="line.product_id.name"/></span>
                        
                        <span class="label-data">
                            LOTE: <t t-esc="line.lot_id.name"/>
                        </span>
                        <span class="label-data" style="font-size: 42px; margin-top: 10px;">
                            Caja: <t t-esc="line.lot_id.name[-4:] if line.lot_id else '0000'"/> 
                            <span style="margin-left: 20px;">Cant: <t t-esc="line.quantity"/></span>
                        </span>

                        <div class="barcode-zone">
                            <t t-if="line.lot_id">
                                <span t-field="line.lot_id.name" 
                                      t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 1400, 'height': 400, 'img_style': 'width:100%; height:32mm;'}"/>
                                <div style="font-size: 16px; font-weight: bold; margin-top: 5px;">
                                    <t t-esc="line.lot_id.name"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>