<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="line">
                <t t-call="web.basic_layout">
                    <style>
                        .label-container {
                            width: 100%;
                            height: 72mm;
                            font-family: 'Helvetica', Arial, sans-serif;
                            color: black;
                            text-align: center;
                            padding-top: 5mm;
                        }
                        .label-ref {
                            font-size: 24px;
                            font-weight: bold;
                            margin-bottom: 15px; /* Mayor separación */
                            display: block;
                        }
                        .label-name {
                            font-size: 18px;
                            line-height: 1.3;
                            margin-bottom: 15px; /* Mayor separación */
                            display: block;
                            padding: 0 5mm;
                            word-wrap: break-word;
                        }
                        .label-data {
                            font-size: 17px;
                            margin-bottom: 12px; /* Mayor separación */
                            display: block;
                        }
                        .barcode-box {
                            margin-top: 20px;
                            width: 100%;
                        }
                        /* Forzar centrado de la imagen del código de barras */
                        .barcode-box img {
                            display: block;
                            margin: 0 auto;
                        }
                    </style>

                    <div class="label-container">
                        <span class="label-ref">
                            Ref: <t t-esc="line.product_id.default_code or 'N/A'"/>
                        </span>
                        
                        <span class="label-name">
                            <t t-esc="line.product_id.name"/>
                        </span>
                        
                        <span class="label-data">
                            <strong>Lote:</strong> <t t-esc="line.lot_id.name"/>
                        </span>
                        
                        <span class="label-data">
                            <strong>Cant:</strong> <t t-esc="line.quantity"/> 
                            <span style="margin-left: 25px;">
                                <strong>Caja:</strong> <t t-esc="line.lot_id.name[-4:] if line.lot_id and line.lot_id.name else '0000'"/>
                            </span>
                        </span>

                        <div class="barcode-box">
                            <t t-if="line.lot_id.name">
                                <span t-field="line.lot_id.name" 
                                      t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 600, 'height': 180, 'img_style': 'width:90%;height:35mm;display:block;margin:auto;'}"/>
                                <div style="font-size: 14px; font-weight: bold; margin-top: 8px;">
                                    <t t-esc="line.lot_id.name"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>