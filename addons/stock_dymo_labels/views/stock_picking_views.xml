<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_dymo_zebra" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.dymo.zebra</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_print_dymo_labels" 
                        string="Imprimir Dymo (PDF)" 
                        type="object" 
                        invisible="picking_type_code != 'incoming'"/>
                
                <button name="action_print_zebra_zpl" 
                        string="Zebra ZT410 (Directo)" 
                        type="object" 
                        class="oe_highlight" 
                        invisible="picking_type_code != 'incoming'"/>
            </xpath>
        </field>
    </record>
</odoo>