<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_textil_direct" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.textil.direct</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="after">
                <field name="show_barcode_scan" invisible="1"/>
                
                <div class="alert alert-info" role="alert" invisible="not show_barcode_scan or state in ['done', 'cancel']">
                    <div style="margin-bottom: 15px; border-bottom: 1px solid #dee2e6; padding-bottom: 10px;">
                        <button name="action_prepare_for_physical_scan" 
                                string="LIMPIAR OPERACIÓN PARA ESCANEO FÍSICO" 
                                type="object" 
                                class="btn-danger" 
                                confirm="¿Desea eliminar las líneas precargadas para iniciar el escaneo físico?"/>
                    </div>
                    
                    <group>
                        <field name="barcode_scan_batch" 
                               string="ESCANEAR ETIQUETA"
                               placeholder="ESCANEE AQUÍ..." 
                               default_focus="1" 
                               autocomplete="off"/>
                    </group>
                </div>
            </xpath>
        </field>
    </record>
</odoo>